generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String     @id @default(uuid())
  phone    String     @unique
  email    String?    @unique
  password String
  role     UserRole
  status   UserStatus @default(PENDING)

  // Security & Activity
  lastFailedLogin DateTime?
  lastLoginIp     String
  loginAttempts   Int       @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  admin          Admin?
  owner          Owner?
  employee       Employee?
  AuditLog       AuditLog[]
  ActiveToken    ActiveToken[]
  TokenBlacklist TokenBlacklist[]

  @@index([phone])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique

  // Personal Info
  name           String
  email          String  @unique
  phone          String  @unique
  profilePicture String?

  // Status
  isDeleted Boolean @default(false)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([name])
  @@map("admins")
}

model Owner {
  id     String @id @default(uuid())
  userId String @unique

  // Personal Info
  name           String
  email          String? @unique
  phone          String  @unique
  profilePicture String?
  address        String?

  // Business Info
  businessName String?
  businessType String?
  taxId        String?

  // Status
  isDeleted  Boolean   @default(false)
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shops Shop[]

  @@index([email])
  @@index([phone])
  @@index([name])
  @@index([taxId])
  @@index([address])
  @@map("owners")
}

model Employee {
  id     String @id @default(uuid())
  userId String @unique
  shopId String

  // Personal Info
  name           String
  email          String? @unique
  phone          String?
  profilePicture String?

  // Employment Info
  employeeCode String   @unique
  salary       Decimal? @db.Decimal(10, 2)
  joiningDate  DateTime @default(now())

  // Emergency Contact
  emergencyName     String
  emergencyPhone    String
  emergencyRelation String

  // Status
  status    EmployeeStatus @default(ACTIVE)
  isDeleted Boolean        @default(false)

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastActiveAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([name])
  @@index([employeeCode])
  @@map("employees")
}

// 🏪 Shop & Infrastructure

model Shop {
  id      String @id @default(uuid())
  ownerId String

  // Basic Info
  name        String
  code        String  @unique
  description String?
  logo        String?

  // Contact Info
  phone   String
  email   String?
  website String?

  // Address
  address   String
  city      String
  division  String?
  zipCode   String?
  country   String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  // Business Hours
  openingTime   String?
  closingTime   String?
  businessHours Json?

  // Status
  status    ShopStatus @default(ACTIVE)
  isDeleted Boolean    @default(false)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  owner         Owner           @relation(fields: [ownerId], references: [userId])
  employees     Employee[]
  Category      Category[]
  Supplier      Supplier[]
  Expense       Expense[]
  DamageProduct DamageProduct[]
  ReturnProduct ReturnProduct[]
  Customer      Customer[]
  Sale          Sale[]
  Discount      Discount[]
  Purchase      Purchase[]
  Warehouse     Warehouse[]
  StockMovement StockMovement[]
  StockAlert    StockAlert[]
  Adjustment    Adjustment[]
  AuditLog      AuditLog[]
  Subcategory   Subcategory[]
  ShopStock     ShopStock[]
  Product       Product[]

  @@index([code])
  @@index([city])
  @@index([name])
  @@index([address])
  @@map("shops")
}

model ShopStock {
  id        String @id @default(uuid())
  productId String
  shopId    String

  quantity     Int @default(0)
  reservedQty  Int @default(0)
  availableQty Int @default(0)

  // Stock Levels
  minStock     Int  @default(1)
  maxStock     Int?
  reorderPoint Int?

  // Location in warehouse
  location String? // Shelf, Bin, etc.

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
  @@index([productId])
  @@index([quantity])
  @@map("shop_stock")
}

model Warehouse {
  id     String @id @default(uuid())
  shopId String

  // Basic Info
  name        String
  code        String  @unique
  description String?

  // Location
  address  String
  city     String
  capacity Int?

  // Manager
  managerId String?

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  warehouseStock WarehouseStock[]

  @@index([shopId])
  @@index([code])
  @@index([city])
  @@index([name])
  @@index([address])
  @@map("warehouses")
}

model WarehouseStock {
  id          String @id @default(uuid())
  warehouseId String
  productId   String

  quantity     Int @default(0)
  reservedQty  Int @default(0)
  availableQty Int @default(0)

  // Stock Levels
  minStock     Int  @default(1)
  maxStock     Int?
  reorderPoint Int?

  // Location in warehouse
  location String? // Shelf, Bin, etc.

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@index([quantity])
  @@map("warehouse_stock")
}

// 📦 Product Management

model Category {
  id     String @id @default(uuid())
  shopId String

  name        String
  description String?
  icon        String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  products      Product[]

  @@unique([shopId, name])
  @@index([shopId])
  @@index([name])
  @@map("categories")
}

model Subcategory {
  id         String @id @default(uuid())
  categoryId String
  shopId     String

  name        String
  description String?
  icon        String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([shopId])
  @@index([name])
  @@map("subcategories")
}

model Product {
  id        String @id @default(uuid())
  productId String @unique

  // Ownership & Categorization
  shopId        String
  categoryId    String?
  subcategoryId String?

  // Basic Info
  name        String
  description String?
  brand       String?

  // Product Identifiers
  barcode String? @unique
  qrCode  String? @unique

  // Pricing (Base/Reference Price)
  buyPrice  Decimal  @db.Decimal(10, 2)
  sellPrice Decimal? @db.Decimal(10, 2)

  // Product Details
  expiryDate DateTime
  quantity   Int      @default(1)

  // Images
  thumbnail String?
  images    String[] @default([])

  // Stock Management
  minStock     Int  @default(1)
  maxStock     Int?
  reorderPoint Int?

  // Cost Management
  avgCost  Decimal? @db.Decimal(10, 2)
  lastCost Decimal? @db.Decimal(10, 2)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category       Category?        @relation(fields: [categoryId], references: [id])
  subcategory    Subcategory?     @relation(fields: [subcategoryId], references: [id])
  DamageProduct  DamageProduct[]
  ReturnProduct  ReturnProduct[]
  SaleItem       SaleItem[]
  PurchaseItem   PurchaseItem[]
  ShopStock      ShopStock[]
  WarehouseStock WarehouseStock[]
  StockMovement  StockMovement[]
  StockAlert     StockAlert[]
  ProductVariant ProductVariant[]
  Adjustment     Adjustment[]

  @@index([shopId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([brand])
  @@index([name])
  @@index([buyPrice])
  @@index([sellPrice])
  @@map("products")
}

model ProductVariant {
  id        String @id @default(uuid())
  productId String

  // Variant Details
  name    String
  sku     String? @unique
  barcode String? @unique

  attributes Json // {size: "L", color: "Red"}

  // Pricing
  buyPrice  Decimal @db.Decimal(10, 2)
  sellPrice Decimal @db.Decimal(10, 2)

  // Stock
  quantity Int  @default(0)
  minStock Int  @default(1)
  maxStock Int?

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([buyPrice])
  @@index([sellPrice])
  @@map("product_variants")
}

model Inventory {
  id String @id @default(uuid())

  // Basic Info
  name        String
  description String?
  brand       String?

  // Product Identifiers
  globalSku String? @unique
  barcode   String? @unique
  qrCode    String? @unique

  // Pricing (Base/Reference Price)
  suggestedBuyPrice  Decimal? @db.Decimal(10, 2)
  suggestedSellPrice Decimal? @db.Decimal(10, 2)
  mrp                Decimal? @db.Decimal(10, 2)

  // Product Details
  manufacturer String?
  weight       Decimal? @db.Decimal(10, 3)
  dimensions   Json?

  // Images
  thumbnail String?
  images    String[] @default([])

  // Additional Info
  tags           String[] @default([])
  specifications Json?

  @@index([brand])
  @@index([name])
  @@map("inventory")
}

// 👥 Business Relationships

model Supplier {
  id     String @id @default(uuid())
  shopId String

  // Basic Info
  name         String
  companyName  String?
  supplierCode String  @unique

  // Contact Info
  email          String
  phone          String
  alternatePhone String

  // Address
  address String
  city    String
  state   String?
  zipCode String?
  country String  @default("Bangladesh")

  //emergency contact
  emergencyName     String
  emergencyPhone    String
  emergencyAddress  String
  emergencyRelation String

  // Business Details
  taxId        String?
  bankName     String?
  bankAccount  String?
  paymentTerms String?
  creditLimit  Decimal? @db.Decimal(10, 2)

  // Status
  status             SupplierStatus @default(ACTIVE)
  totalOrder         Int?           @default(0)
  rating             Int?           @default(0)
  productRating      Int?           @default(0)
  deliveryTimeRating Int?           @default(0)
  afterServiceRating Int?           @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop          Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ReturnProduct ReturnProduct[]
  Purchase      Purchase[]

  @@unique([shopId, supplierCode])
  @@index([shopId])
  @@index([status])
  @@index([companyName])
  @@index([email])
  @@index([phone])
  @@index([bankAccount])
  @@index([address])
  @@index([city])
  @@index([taxId])
  @@map("suppliers")
}

model Customer {
  id     String @id @default(uuid())
  shopId String

  // Basic Info
  name  String
  phone String
  email String?

  // Address
  address String?
  city    String?
  area    String?

  // Customer Details
  customerType CustomerType @default(REGULAR)
  membershipNo String?      @unique

  // Status
  status CustomerStatus @default(ACTIVE)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastVisit DateTime?

  // Relations
  shop  Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@unique([shopId, phone])
  @@index([shopId])
  @@index([phone])
  @@index([customerType])
  @@index([status])
  @@index([email])
  @@index([address])
  @@index([city])
  @@map("customers")
}

// 💰 Transactions

model Purchase {
  id         String @id @default(uuid())
  shopId     String
  supplierId String

  // Purchase Details
  invoiceNo   String  @unique
  referenceNo String?
  totalAmount Decimal @db.Decimal(10, 2)
  paidAmount  Decimal @default(0) @db.Decimal(10, 2)
  dueAmount   Decimal @default(0) @db.Decimal(10, 2)

  // Status
  status        PurchaseStatus @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)

  // Dates
  purchaseDate DateTime  @default(now())
  deliveryDate DateTime?
  expectedDate DateTime?

  // Relations
  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]

  @@index([shopId])
  @@index([supplierId])
  @@index([status])
  @@index([purchaseDate])
  @@index([paidAmount])
  @@index([dueAmount])
  @@index([totalAmount])
  @@index([invoiceNo])
  @@index([shopId, purchaseDate, status])
  @@index([supplierId, status, purchaseDate])
  @@index([paymentStatus, purchaseDate])
  @@index([shopId, paymentStatus, dueAmount])
  @@map("purchases")
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  productId  String

  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  receivedQty Int     @default(0)

  // Relations
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Sale {
  id         String  @id @default(uuid())
  shopId     String
  customerId String?

  invoiceNo String @unique

  // Items & Amounts
  items    Json // [{productId, quantity, unitPrice, discount, total}]
  subtotal Decimal @db.Decimal(10, 2)

  // Discount Details
  discountId      String?
  discountType    DiscountType?
  discountAmount  Decimal?      @db.Decimal(10, 2)
  discountPercent Decimal?      @db.Decimal(5, 2)

  // Total
  totalAmount Decimal @db.Decimal(10, 2)

  // Payment
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PAID)
  referenceNo   String?
  paidAmount    Decimal       @db.Decimal(10, 2)
  dueAmount     Decimal       @default(0) @db.Decimal(10, 2)

  // Additional Info
  notes String?

  // Processing
  soldBy String

  // Status
  status SaleStatus @default(COMPLETED)

  // Dates
  saleDate DateTime @default(now())

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer  Customer?  @relation(fields: [customerId], references: [id])
  discount  Discount?  @relation(fields: [discountId], references: [id])
  saleItems SaleItem[]

  @@index([shopId])
  @@index([customerId])
  @@index([soldBy])
  @@index([saleDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([paidAmount])
  @@index([dueAmount])
  @@index([totalAmount])
  @@index([discountAmount])
  @@index([shopId, saleDate])
  @@index([shopId, status, saleDate])
  @@index([customerId, saleDate])
  @@index([soldBy, saleDate])
  @@index([shopId, paymentStatus, saleDate])
  @@index([paymentMethod, saleDate])
  @@map("sales")
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String

  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)

  // Discount
  discount Decimal @default(0) @db.Decimal(10, 2)

  // Total
  totalPrice Decimal @db.Decimal(10, 2)

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Discount {
  id     String @id @default(uuid())
  shopId String

  // Basic Info
  name        String
  code        String  @unique
  description String?

  // Discount Configuration
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)

  // Conditions
  minPurchaseAmount Decimal? @db.Decimal(10, 2)
  maxDiscountAmount Decimal? @db.Decimal(10, 2)

  // Applicable To
  applicableType DiscountApplicableType @default(ALL)
  productIds     String[]               @default([])
  categoryIds    String[]               @default([])
  customerTypes  CustomerType[]         @default([])

  // Validity
  validFrom DateTime
  validTo   DateTime

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop  Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@index([shopId])
  @@index([isActive])
  @@index([name])
  @@index([code])
  @@index([discountType])
  @@index([validFrom, validTo])
  @@map("discounts")
}

// 📊 Operations & Tracking

model Expense {
  id     String @id @default(uuid())
  shopId String

  category      ExpenseCategory
  amount        Decimal         @db.Decimal(10, 2)
  paymentMethod PaymentMethod   @default(CASH)
  referenceNo   String?         @unique

  title       String
  description String?

  // Attachments
  attachments String[] @default([])

  // Dates
  expenseDate DateTime @default(now())

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([category])
  @@index([expenseDate])
  @@index([amount])
  @@index([title])
  @@index([referenceNo])
  @@index([shopId, expenseDate, category])
  @@map("expenses")
}

model DamageProduct {
  id        String @id @default(uuid())
  shopId    String
  productId String

  // Damage Details
  quantity   Int
  damageType DamageType
  severity   DamageSeverity @default(PARTIAL)

  // Description
  reason      String
  description String?

  // Financial Impact
  totalLoss       Decimal  @db.Decimal(10, 2)
  isRecoverable   Boolean  @default(false)
  recoveredAmount Decimal? @db.Decimal(10, 2)

  // Evidence
  images String[] @default([])

  // Dates
  damageDate DateTime @default(now())

  // Status
  status     DamageStatus @default(REPORTED)
  resolvedAt DateTime?
  resolution String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@index([damageDate])
  @@map("damage_products")
}

model ReturnProduct {
  id        String @id @default(uuid())
  shopId    String
  productId String

  // Return Type & Direction
  returnType ReturnType

  // Common Fields
  quantity    Int
  reason      ReturnReason
  condition   ProductCondition @default(GOOD)
  description String?
  images      String[]         @default([])

  // Reference Numbers
  referenceNo     String?
  invoiceNo       String?
  returnInvoiceNo String? @unique

  // Customer Return Specific (when returnType = CUSTOMER_RETURN)
  customerName     String?
  customerPhone    String?
  customerComments String?
  refundAmount     Decimal?       @db.Decimal(10, 2)
  refundMethod     PaymentMethod?
  restockingFee    Decimal?       @db.Decimal(10, 2)
  saleDate         DateTime?

  // Supplier Return Specific (when returnType = SUPPLIER_RETURN)
  supplierId        String?
  supplierInvoiceNo String?
  purchaseDate      DateTime?

  // Status
  status ReturnStatus @default(PENDING)

  // Important Dates
  returnDate         DateTime  @default(now())
  approvedAt         DateTime?
  shippedAt          DateTime?
  receivedAt         DateTime?
  completedAt        DateTime?
  expectedRefundDate DateTime?

  // Financial Settlement
  isSettled        Boolean        @default(false)
  settledAt        DateTime?
  settlementMethod PaymentMethod?
  settlementRef    String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([shopId])
  @@index([productId])
  @@index([supplierId])
  @@index([status])
  @@index([returnType])
  @@index([returnDate])
  @@index([customerPhone])
  @@map("return_products")
}

// 📈 Inventory Control

model StockMovement {
  id        String @id @default(uuid())
  shopId    String
  productId String

  // Movement Details
  movementType MovementType
  quantity     Int
  reference    String? // Reference to sale, purchase, damage, etc.

  // Stock Levels
  previousStock Int
  currentStock  Int

  // Details
  reason      String?
  description String?

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
  @@index([shopId, createdAt, movementType])
  @@index([productId, createdAt, movementType])
  @@map("stock_movements")
}

model StockAlert {
  id        String @id @default(uuid())
  shopId    String
  productId String

  alertType    AlertType
  threshold    Int
  currentStock Int
  message      String

  // Status
  isActive   Boolean   @default(true)
  resolvedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([productId])
  @@index([alertType])
  @@index([isActive])
  @@map("stock_alerts")
}

model Adjustment {
  id        String @id @default(uuid())
  shopId    String
  productId String

  // Adjustment Details
  type           AdjustmentType
  quantityBefore Int
  quantityAfter  Int
  adjustmentQty  Int

  // Reason
  reason      AdjustmentReason
  description String?

  // Authorization
  approvedBy String?
  approvedAt DateTime?

  // References
  referenceNo String?

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("adjustments")
}

// 🔍 System & Security

model ActiveToken {
  id         String    @id @default(uuid())
  tokenId    String    @unique
  userId     String
  ipAddress  String?
  deviceInfo Json?
  lastUsed   DateTime  @default(now())
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  tokenType  TokenType
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenId])
}

model TokenBlacklist {
  id            String    @id @default(uuid())
  tokenId       String    @unique
  tokenType     TokenType
  userId        String?
  issuedAt      DateTime
  expiresAt     DateTime
  blacklistedAt DateTime  @default(now())
  reason        String?
  ipAddress     String?
  user          User?     @relation(fields: [userId], references: [id])

  @@index([tokenId])
  @@index([expiresAt])
  @@index([userId])
}

model AuditLog {
  id String @id @default(uuid())

  // Context
  shopId String?
  userId String

  // Action Details
  action     AuditAction
  entity     String // table name (e.g., "products", "users", "sales")
  entityId   String // ID of the affected record
  entityName String? // Human readable name (e.g., product name, user name)

  // Changes
  oldValues Json? // Previous values before change
  newValues Json? // New values after change
  changes   Json? // Specific fields that changed with before/after

  // Request Context
  ipAddress String?
  userAgent String?
  endpoint  String? // API endpoint or page URL
  method    String? // GET, POST, PUT, DELETE

  // Additional Context
  reason      String? // Why the action was performed
  description String? // Additional details
  metadata    Json? // Extra contextual data

  // Status
  status AuditStatus @default(SUCCESS)
  error  String? // Error message if failed

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  user User  @relation(fields: [userId], references: [id])
  shop Shop? @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@index([status])
  @@index([action, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([userId, action, createdAt])
  @@map("audit_logs")
}

